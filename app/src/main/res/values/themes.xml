<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="ShapeAppearance.Web2App.Icon" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">24dp</item>
    </style>

    <!--
        Dialog buttons default to colorPrimary, which some of our theme accents don't contrast
        well against colorSurface (e.g. dark themes with a muted accent). Forcing colorOnSurface
        here guarantees legible button text, matching the title/message color, at the cost of the
        buttons no longer being accent-colored inside dialogs specifically.
    -->
    <style name="ThemeOverlay.Web2App.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">?attr/colorOnSurface</item>
    </style>

    <style name="Theme.Web2App" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/purple_700</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Web2App.AlertDialog</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="fontFamily">sans-serif-condensed</item>
    </style>

    <style name="Theme.Web2App.NoActionBar" parent="Theme.Web2App">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Web2App.Blue" parent="Theme.Material3.Light">
